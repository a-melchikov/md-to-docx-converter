{
  "name": "@md-to-docx/docx-adapter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "lint": "eslint src tests --max-warnings=0",
